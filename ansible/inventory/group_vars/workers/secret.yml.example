---
# discord-bot-cli 設定（gitignore 対象）
# このファイルをコピーして secret.yml を作成し、実際の値を記入すること
# cp secret.yml.example secret.yml

server_setup_discord_bot_cli_config_token: "<your Discord Bot Token>"
server_setup_discord_bot_cli_config_channels:
  - name: system
    id: "<your Discord Channel ID>"
  - name: nextcloud
    id: "<your Discord Channel ID>"
  - name: growi
    id: "<your Discord Channel ID>"
